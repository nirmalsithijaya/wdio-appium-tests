    body: {
      lang: 'ecmascript',
      code: 'async () => {\n' +
        `    await $('//android.widget.TextView[@text="Active"]').click();\n` +
        '\n' +
        '    // Wait for the dialog message to appear\n' +
        `    const dialogMessage = await $('//*[@resource-id="android:id/message"]');\n` +
        '    await dialogMessage.waitForDisplayed();\n' +
        '    await expect(dialogMessage).toHaveText("This button is active");\n' +
        '\n' +
        '    // Click OK button to close the modal\n' +
        `    const okButton = await $('//*[@resource-id="android:id/button1"]');\n` +
        '    await okButton.click();\n' +
        '\n' +
        '    // Verify modal is closed by checking the message is no longer displayed\n' +
        '    await expect(dialogMessage).not.toBeDisplayed();\n' +
        '  }'
    },
